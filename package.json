{
  "name": "icloud-notes-sync",
  "version": "0.1.0",
  "type": "module",
  "description": "Sync Apple Notes to a git-backed local folder via CloudKit's private web services.",
  "license": "MIT",
  "author": "Adam Coddington",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coddingtonbear/icloud-notes-sync.git"
  },
  "homepage": "https://github.com/coddingtonbear/icloud-notes-sync#readme",
  "bugs": {
    "url": "https://github.com/coddingtonbear/icloud-notes-sync/issues"
  },
  "keywords": [
    "apple-notes",
    "icloud",
    "notes",
    "sync",
    "cli",
    "git"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "icloud-notes": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "import-har": "tsx src/scripts/importHar.ts",
    "test": "tsx --test $(find src -name '*.test.ts')"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "node-diff3": "^3.2.1",
    "ora": "^9.4.1",
    "playwright": "^1.61.1"
  }
}

    "typecheck": "tsc -p tsconfig.json --noEmit",
    "import-har": "tsx src/scripts/importHar.ts",
    "cli": "tsx src/cli.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

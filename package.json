{
  "name": "icloud-notes-sync",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Sync Apple Notes to a git-backed local folder via CloudKit's private web services.",
  "bin": {
    "icloud-notes-sync": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "import-har": "tsx src/scripts/importHar.ts",
    "cli": "tsx src/cli.ts",
    "test": "tsx --test src/**/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@foxt/js-srp": "0.0.3-patch2",
    "node-diff3": "^3.2.1"
  }
}
